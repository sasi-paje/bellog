// ============================================================================
// TIPOS - Domain Types
// ============================================================================

interface NoteItem {
  id: string
  invoice_number: string
  weight: number
  volume: number
  fornecedor?: string
  caixas?: number
  value?: number
  issue_date?: string
  destination_name?: string
}

interface AssignedNote {
  id: string
  invoice_number: string
  peso: number
  destination_name?: string
}

interface RouteCardData {
  id: string
  tipoRota: string
  numeroRota: string
  veiculo: string
  capacidade: number
  cargaAtual: number
  notasAtribuidas: AssignedNote[]
  isTemporary: boolean
  hasPendingChanges: boolean
  canCreate: boolean
  canEdit: boolean
  buttonLabel: string
  buttonColor: 'gray' | 'orange'
  id_vehicle?: string
  route_status?: string
  status_description?: string
}

interface AssignNotesPageProps {
  userName?: string
  userRole?: string
  isSidebarOpen?: boolean
  onToggleSidebar?: () => void
}

// ============================================================================
// CAMADA DE ESTADO - State Management
// ============================================================================

// Estado persistido (vem do banco)
interface PersistedState {
  routes: RouteListItem[]
  routeNotes: Record<string, AssignedNote[]> // routeId -> notas do banco
}

// Estado temporário (ainda não salvo)
interface TemporaryState {
  localRouteNotes: Record<string, AssignedNote[]> // routeId/vehicleId -> notas temporárias
  localUnassignedNotes: NoteItem[]
  dirtyRoutes: Set<string> // rotas com alteração pendente
  pendingAssignments: Record<string, string[]> // vehicleId -> notas pendentes de criar rota
}

// Estado de UI
interface UIState {
  selectedRouteId: string | null
  loading: boolean
  searchTerm: string
  currentPage: number
  totalPages: number
  isFilterModalOpen: boolean
  isCreateDrawerOpen: boolean
  isEditDrawerOpen: boolean
  isConfirmModalOpen: boolean
  isRemoveModalOpen: boolean
  isNoteDetailOpen: boolean
  pendingNote: NoteItem | null
  pendingRoute: RouteListItem | null
  pendingRemoveNote: { routeId: string; noteId: string; invoiceNumber: string } | null
  selectedNote: InvoiceListItem | null
  createRouteData: any
  editRouteData: any
}

// ============================================================================
// COMANDOS DE NEGÓCIO - Business Commands
// ============================================================================

/**
 * Command: Cria uma nova rota com notas vinculadas
 * 1. Cria registro em trx_route
 * 2. Vincula notas em rel_route_invoice
 * 3. Recarrega dados
 */
async function createRouteWithInvoices(
  vehicle: MasterFleetVehicle,
  notes: AssignedNote[],
  routeData: any
): Promise<void> {
  const isTest = true // ou buscar do environment

  // 1. Criar rota
  const { data: newRoute, error: routeError } = await supabase
    .from('trx_route')
    .insert({
      route_code: routeData.numeroRota,
      departure_date: routeData.dataSaida,
      id_route_status: routeData.status,
      id_route_delivery_status: routeData.statusEntrega,
      id_vehicle: vehicle.id,
      id_driver: routeData.motorista || null,
      observation: routeData.responsaveis || null,
      area: routeData.areaRota || null,
      responsible: routeData.responsaveis || null,
      assistant: routeData.ajudante || null,
      is_test: isTest,
      is_active: true,
    })
    .select()
    .single()

  if (routeError) throw new Error(routeError.message)

  // 2. Vincular notas
  if (notes.length > 0) {
    const invoiceLinks = notes.map(note => ({
      id_route: newRoute.id,
      id_fiscal_invoice: parseInt(note.id, 10),
      assigned_at: new Date().toISOString(),
      is_test: isTest,
      is_active: true,
    }))

    const { error: linkError } = await supabase
      .from('rel_route_invoice')
      .insert(invoiceLinks)

    if (linkError) throw new Error(linkError.message)
  }
}

/**
 * Command: Atualiza rota e sincroniza notas
 * 1. Atualiza dados da rota
 * 2. Sincroniza notas (add/remove/reactivate)
 */
async function updateRouteAndSyncInvoices(
  routeId: string,
  routeData: any,
  finalNoteIds: string[]
): Promise<void> {
  // 1. Atualizar dados da rota
  await routeService.update(routeId, {
    id_route_status: routeData.status || null,
    id_route_delivery_status: routeData.statusEntrega || null,
    departure_date: routeData.dataSaida || null,
    ends_at: routeData.fimRota || null,
    id_driver: routeData.motorista || null,
    assistant: routeData.ajudante || null,
    observation: routeData.responsaveis || null,
    responsible: routeData.responsaveis || null,
  })

  // 2. Sincronizar notas
  if (finalNoteIds.length >= 0) {
    await assignmentService.syncRouteInvoices(routeId, finalNoteIds)
  }
}

/**
 * Command: Remove nota de rota persistida (soft delete)
 */
async function removeInvoiceFromPersistedRoute(
  routeId: string,
  noteId: string
): Promise<void> {
  await assignmentService.unassignInvoiceFromRoute(routeId, noteId)
}

/**
 * Command: Carrega dados da rota para edição
 */
async function loadRouteForEdit(routeId: string): Promise<any> {
  const routeDetails = await routeService.getById(routeId)
  if (!routeDetails) return null

  // Buscar notas vinculadas para exibir no campo destinos
  const invoices = await fiscalInvoiceService.getByRouteId(routeId)

  // Mapear notas para destinos (nome do cliente)
  const destinos = invoices.map(inv => ({
    value: inv.id,
    label: inv.destination_name || `NF ${inv.invoice_number}`
  }))

  return {
    status: routeDetails.id_route_status ? String(routeDetails.id_route_status) : '',
    statusEntrega: routeDetails.id_route_delivery_status ? String(routeDetails.id_route_delivery_status) : '',
    numeroRota: routeDetails.route_code || '',
    areaRota: routeDetails.area || routeDetails.route_area?.description || '',
    responsaveis: routeDetails.observation || routeDetails.responsible || '',
    destinos,
    tipoRota: routeDetails.id_route_type ? String(routeDetails.id_route_type) : '',
    dataSaida: routeDetails.departure_date || '',
    fimRota: (routeDetails as any).ends_at || '',
    motorista: routeDetails.drivers?.[0]?.id ? String(routeDetails.drivers[0].id) : '',
    ayudante: routeDetails.assistant || routeDetails.helpers?.[0]?.name || '',
    // Dados do veículo vem da rota
    placaVeiculo: '',
    cargaMaxima: '500',
  }
}

// ============================================================================
// CARD BUILDER - View Model
// ============================================================================

/**
 * Constrói o modelo do card com todas as regras de negócio
 */
function buildRouteCard(
  route: RouteListItem | null,
  vehicle: MasterFleetVehicle | null,
  dbNotes: AssignedNote[],
  localNotes: AssignedNote[],
  isTemporary: boolean,
  isDirty: boolean
): RouteCardData {
  // Determinar notas do card
  const notasAtribuidas = localNotes.length > 0 ? localNotes : dbNotes
  const cargaAtual = notasAtribuidas.reduce((sum, n) => sum + (n.peso || 0), 0)
  const capacidade = vehicle?.max_capacity || 500

  // Regras de negócio para botões
  let buttonLabel: string
  let buttonColor: 'gray' | 'orange'
  let canCreate: boolean
  let canEdit: boolean

  if (isTemporary) {
    // Card temporário (sem rota criada)
    canCreate = true
    canEdit = false
    buttonLabel = 'Criar Rota'
    buttonColor = notasAtribuidas.length > 0 ? 'orange' : 'gray'
  } else {
    // Card com rota persistida
    canEdit = true
    canCreate = false
    buttonLabel = 'Alterar Rota'
    buttonColor = isDirty ? 'orange' : 'gray'
  }

  const cardId = isTemporary ? `vehicle-${vehicle?.id}` : route?.id || ''

  return {
    id: cardId,
    tipoRota: route?.area_description || (isTemporary ? 'Nova Rota' : 'Rota'),
    numeroRota: route?.route_code || '',
    veiculo: vehicle?.plate || (isTemporary ? 'Sem veículo' : ''),
    capacidade,
    cargaAtual,
    notasAtribuidas,
    isTemporary,
    hasPendingChanges: isDirty,
    canCreate,
    canEdit,
    buttonLabel,
    buttonColor,
    id_vehicle: vehicle?.id,
    route_status: route?.status,
    status_description: route?.status_description,
  }
}

