{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/my-routes(.*)", "destination": "/index.html" },
    { "source": "/delivery(.*)", "destination": "/index.html" },
    { "source": "/chegada(.*)", "destination": "/index.html" },
    { "source": "/arrival-client(.*)", "destination": "/index.html" }
  ]
}
